{
  "name": "@mud/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @mud/shared build",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "report:values:equipment": "pnpm build && node dist/tools/report-equipment-values.js",
    "report:values:technique": "pnpm build && node dist/tools/report-technique-values.js",
    "report:values:skill": "pnpm build && node dist/tools/report-skill-values.js",
    "report:values:buff": "pnpm build && node dist/tools/report-buff-values.js",
    "report:values:all": "pnpm build && node dist/tools/report-all-values.js",
    "report:values:docs": "pnpm build && node dist/tools/export-value-reports.js"
  },
  "dependencies": {
    "@mud/shared": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^10.0.0",
    "bcrypt": "^6.0.0",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.7.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/bcrypt": "^6.0.0",
    "typescript": "^5.3.0"
  }
}
